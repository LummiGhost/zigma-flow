{
  "name": "@zigma-ai/zigma-flow",
  "version": "0.5.0",
  "description": "Local Agent Workflow Runtime / Workflow Harness.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "zigma-flow": "./dist/cli.js"
  },
  "files": [
    "dist",
    "docs/wiki"
  ],
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:unit": "vitest run tests/artifact tests/check tests/context tests/dag tests/events tests/expression tests/git tests/prompt tests/router tests/run tests/script tests/workflow",
    "test:integration": "vitest run tests/commands tests/engine tests/init",
    "test:e2e": "vitest run tests/dogfood tests/cli",
    "test:ci": "vitest run",
    "smoke": "node dist/cli.js --help",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "devDependencies": {
    "@types/micromatch": "^4.0.9",
    "@types/node": "^20.19.42",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "commander": "^12.1.0",
    "execa": "^9.6.1",
    "micromatch": "^4",
    "simple-git": "^3",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  }
}
